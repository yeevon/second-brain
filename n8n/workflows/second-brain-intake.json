    {
      "parameters": {
        "jsCode": "// Build Gemini generateContent request — ask for full Classification matching models.py\nconst captureText = $('Get Capture').first().json.raw_text ?? '';\nconst prompt = [\n  'Classify the following personal note into a structured knowledge item.',\n  '',\n  'Allowed folder values: inbox, people, projects, ideas, learning, admin',\n  'Allowed action status values: open, done',\n  '',\n  'Capture:',\n  captureText,\n  '',\n  'Return compact JSON only. Keep body under 80 words. At most one action.',\n  'Respond with a single JSON object only (no markdown fences, no other text):',\n  '{',\n  '  \"folder\": \"inbox\",',\n  '  \"project\": null,',\n  '  \"note_type\": \"general\",',\n  '  \"title\": \"concise title\",',\n  '  \"tags\": [\"tag1\"],',\n  '  \"body\": \"brief note body\",',\n  '  \"actions\": [{\"text\": \"example action\", \"status\": \"open\"}],',\n  '  \"needs_clarification\": false,',\n  '  \"clarifying_question\": null,',\n  '  \"confidence\": 0.9',\n  '}',\n].join('\\n');\n\nreturn [{\n  json: {\n    contents: [{ parts: [{ text: prompt }] }],\n    generationConfig: { temperature: 0, maxOutputTokens: 2048 },\n  }\n}];"
      },
      "id": "a1b2c3d4-6666-6666-6666-666666666666",
      "name": "Prepare Gemini Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2420,
        60
      ]
    },

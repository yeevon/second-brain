DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CAPTURE_CHANNEL_ID=
DISCORD_ALLOWED_USER_ID=

CAPTURE_PROCESSING_MODE=local-full

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
CLASSIFICATION_CONFIDENCE_THRESHOLD=0.75
CLASSIFIER_WORKER_COUNT=1
CLASSIFIER_QUEUE_MAXSIZE=100

VAULT_PATH=/home/your-name/src/vault
LEDGER_PATH=.runtime/ledger.sqlite3

# Local vault host path (optional, local dev only).
# When set, writer-service and vault-init use this host directory as the vault
# instead of the Docker named volume. This makes the vault directly visible to
# Obsidian and to host-side brain-mcp without going through Docker.
#
# Example:
#   LOCAL_VAULT_PATH=/home/your-name/prj/my-vault
#
# Leave unset to use the Docker named volume (second-brain-local-vault).
# Production deployments ignore this variable entirely.
LOCAL_VAULT_PATH=

# MCP client configuration (host process, recommended).
# Install the package and point AI clients at the host brain-mcp binary:
#
#   uv sync   # or: pip install -e .
#
# Claude Code / Claude Desktop (~/.claude/mcp_config.json or settings.json):
#   {
#     "mcpServers": {
#       "second-brain": {
#         "command": "uv",
#         "args": ["run", "brain-mcp"],
#         "env": {
#           "VAULT_PATH": "/home/your-name/prj/my-vault",
#           "LEDGER_PATH": "/home/your-name/prj/second-brain/.runtime/ledger.sqlite3"
#         }
#       }
#     }
#   }
#
# LEDGER_PATH is optional — omit it if you only need vault search/read tools.
# get_sync_status will report ledger_exists: false but vault tools work fine.
STARTUP_RECONCILE_LIMIT=100
PERIODIC_RECONCILE_INTERVAL_SECONDS=60
PERIODIC_RECONCILE_LIMIT=100

# Delivery dispatcher and reaper (safe defaults; override only if needed)
DELIVERY_RETRY_MAX_ATTEMPTS=5
DELIVERY_RETRY_BASE_DELAY_SECONDS=10
DELIVERY_RETRY_MAX_DELAY_SECONDS=300
DELIVERY_FORWARD_LEASE_SECONDS=60
DELIVERY_PROCESSING_LEASE_SECONDS=300
DELIVERY_DISPATCH_INTERVAL_SECONDS=2
DELIVERY_DISPATCH_BATCH_SIZE=25
STALE_LEASE_REAPER_INTERVAL_SECONDS=30
STALE_LEASE_REAPER_BATCH_SIZE=100

# Capture-service heartbeat (safe defaults; override only if needed)
CAPTURE_SERVICE_INTERNAL_TOKEN=
CAPTURE_API_HOST=127.0.0.1
CAPTURE_API_PORT=8000
CAPTURE_SERVICE_HEARTBEAT_INTERVAL_SECONDS=15
CAPTURE_SERVICE_HEALTH_STALE_AFTER_SECONDS=60

# Status command timezone
STATUS_TIMEZONE=UTC

# SQLite runtime (safe defaults; override only if needed)
SQLITE_BUSY_TIMEOUT_MS=1000
SQLITE_BUSY_RETRY_ATTEMPTS=5
SQLITE_BUSY_RETRY_BASE_DELAY_MS=25
SQLITE_JOB_QUEUE_MAXSIZE=10000

# Downstream delivery to n8n (disabled by default)
DOWNSTREAM_DELIVERY_ENABLED=false
# When enabled the URL must be exactly: http://n8n:5678/webhook/second-brain-intake
N8N_INTAKE_WEBHOOK_URL=
# At least 32 characters; set the matching value as an n8n Header Auth credential
N8N_INTAKE_WEBHOOK_TOKEN=
DELIVERY_WEBHOOK_TIMEOUT_SECONDS=10

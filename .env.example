# Copy this to .env and fill in your values
# Never commit .env to git

# Discord
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_BRAIN_DUMP_CHANNEL_ID=
DISCORD_DM_USER_ID=

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# GitHub (for vault sync)
GITHUB_TOKEN=
GITHUB_VAULT_REPO=your-username/your-vault-repo
GITHUB_VAULT_BRANCH=main

# n8n
N8N_WEBHOOK_URL=http://your-ec2-ip:5678

# Vault (local path on your main PC for MCP)
VAULT_LOCAL_PATH=/path/to/your/local/vault

# Prompt versioning (bump this when you change prompts)
PROMPT_VERSION=1.0.0
# Writer-stub internal authentication
# n8n must send X-Writer-Stub-Token: <value> on every request.
# Generate with: openssl rand -hex 32
# Set the same value in deploy/n8n.env.example as WRITER_STUB_WEBHOOK_TOKEN.
WRITER_STUB_INTERNAL_TOKEN=

# capture-service endpoint and authentication
# On EC2 the service is reachable over the backend Docker network.
CAPTURE_SERVICE_URL=http://capture-service:8000
CAPTURE_SERVICE_INTERNAL_TOKEN=

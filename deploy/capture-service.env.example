# Discord intake
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CAPTURE_CHANNEL_ID=
DISCORD_ALLOWED_USER_ID=

# Runtime
CAPTURE_PROCESSING_MODE=capture-only

# Persistent SQLite storage inside the container
LEDGER_PATH=/var/lib/second-brain/ledger.sqlite3

# Internal API
CAPTURE_API_HOST=0.0.0.0
CAPTURE_API_PORT=8000
CAPTURE_SERVICE_INTERNAL_TOKEN=

# Reconciliation
STARTUP_RECONCILE_LIMIT=100

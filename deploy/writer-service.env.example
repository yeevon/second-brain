# writer-service runtime

# Shared authentication token for n8n → writer-service requests.
# Minimum 32 characters. Keep separate from capture-service tokens.
WRITER_SERVICE_TOKEN=

# Vault filesystem path inside the container (matches compose volume mount).
VAULT_PATH=/opt/vault

# Audit log path inside the container.
AUDIT_LOG_PATH=/opt/vault/99_log/events.ndjson

# Logging
LOG_LEVEL=INFO

# Git vault sync (branch is always main)
VAULT_REMOTE=git@github.com:<org-or-user>/second-brain-vault.git
GIT_SYNC_ENABLED=true

# SB-119: Backup configuration — copy to backup.env and fill in values.
# This file must NOT contain real secrets; use it as a template only.

# Absolute path to the live SQLite ledger
LEDGER_PATH=/opt/second-brain/data/runtime/ledger.sqlite3

# Absolute path to the vault git clone
VAULT_PATH=/opt/second-brain/vault

# Destination directory for encrypted backup archives
BACKUP_DEST=/opt/second-brain/backups

# GPG recipient key ID or email used to encrypt backup artefacts
GPG_RECIPIENT=your-key-id-or-email@example.com

# Path to n8n data volume (leave blank to skip)
N8N_DATA_DIR=/opt/second-brain/data/n8n

# Path to service config directory (leave blank to skip)
CONFIG_DIR=/opt/second-brain/config
